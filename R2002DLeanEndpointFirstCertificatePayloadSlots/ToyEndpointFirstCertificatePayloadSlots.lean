/-- Toy-style check: forgetting payload slots returns the certificate dependency map. -/
theorem toy_endpoint_first_certificate_payload_slots_to_certificate_dependency_map_runs
    {OD : EndpointConcreteDischargeObligationDependencyTable OS}
    {CI : MainAnchoredEndpointFirstDischargeCertificateInterface OD}
    {CM : EndpointFirstDischargeCertificateDependencyMap CI}
    (PS : MainAnchoredEndpointFirstCertificatePayloadSlots CM) :
    endpoint_first_certificate_payload_slots_to_certificate_dependency_map PS = CM := by
  rfl

/-- Toy-style check: payload slots inherit the actual-Li target. -/
theorem toy_endpoint_first_certificate_payload_slots_to_actual_li_target_runs
    {OD : EndpointConcreteDischargeObligationDependencyTable OS}
    {CI : MainAnchoredEndpointFirstDischargeCertificateInterface OD}
    {CM : EndpointFirstDischargeCertificateDependencyMap CI}
    (PS : MainAnchoredEndpointFirstCertificatePayloadSlots CM) :
    A.actualLiTarget := by
  exact endpoint_first_certificate_payload_slots_to_actual_li_target PS

/-- Toy-style check: forgetting a payload dependency plan returns the payload slots. -/
theorem toy_endpoint_first_certificate_payload_dependency_plan_to_slots_runs
    {OD : EndpointConcreteDischargeObligationDependencyTable OS}
    {CI : MainAnchoredEndpointFirstDischargeCertificateInterface OD}
    {CM : EndpointFirstDischargeCertificateDependencyMap CI}
    {PS : MainAnchoredEndpointFirstCertificatePayloadSlots CM}
    (PD : EndpointFirstCertificatePayloadDependencyPlan PS) :
    endpoint_first_certificate_payload_dependency_plan_to_payload_slots PD = PS := by
  rfl

