    (AC : MainAnchoredEndpointFirstConcreteObligationLemmaDependencyGraph AB) :
    EndpointFirstConcreteObligationLemmaDependencyGraphDependencyAudit AC :=
  { auditItemCount := AC.dependencyGraphStageCount
    attachedToLemmaStatementBank := AC.allDependencyGraphNodesStillOpen
    recordsEndpointEstimateDependency := AC.recordsEndpointEstimateDependency
    recordsExplicitFormulaDependency := AC.recordsExplicitFormulaDependency
    recordsTransferAssemblyDependency := AC.recordsTransferAssemblyDependency
    recordsFiniteAbelReductionDependency := AC.recordsFiniteAbelReductionDependency
    recordsProofKernelConnectionDependency := AC.recordsProofKernelConnectionDependency
    recordsAllGraphNodesStillOpen := AC.allDependencyGraphNodesStillOpen
    actualLiTarget := AC.actualLiTarget }

